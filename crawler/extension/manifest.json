{
  "manifest_version": 3,
  "name": "Boss直聘职位采集器",
  "version": "1.0.0",
  "description": "自动采集Boss直聘职位，推送飞书多维表格",
  "permissions": [
    "storage",
    "alarms",
    "cookies",
    "activeTab",
    "scripting",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://www.zhipin.com/*",
    "https://*.51job.com/*",
    "https://*.zhaopin.com/*",
    "https://open.feishu.cn/*",
    "http://127.0.0.1:7893/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.zhipin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.51job.com/*"],
      "js": ["content-51job.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.zhaopin.com/*"],
      "js": ["content-zhaopin.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["zhaopin-main-world.js", "boss-stealth.js"],
      "matches": ["https://*.zhaopin.com/*", "https://www.zhipin.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Boss直聘职位采集器"
  }
}
